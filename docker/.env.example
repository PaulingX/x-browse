# x-browse 环境变量配置
# 复制此文件为 .env 并修改配置

# 对外访问端口
PORT=2401

# 管理员初始密码（首次启动生效，登录后请修改）
XBROWSE_ADMIN_PASSWORD=admin123

# JWT 密钥（请修改为随机字符串）
XBROWSE_JWT_SECRET=xbrowse-secret-key-change-this-to-random-string

# JWT 过期时间（秒，默认7天）
XBROWSE_JWT_EXPIRATION=604800

# 缩略图生成开关（true/false）
XBROWSE_THUMBNAIL_ENABLED=true
